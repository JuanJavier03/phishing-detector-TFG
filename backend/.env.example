DATABASE_URL=postgresql+psycopg://app_user:app_password@localhost:5432/phishing_detector

# Credenciales y timeouts de Neutrino.
NEUTRINO_USER_ID=
NEUTRINO_API_KEY=
NEUTRINO_BASE_URL=https://eu.neutrinoapi.net
NEUTRINO_CONNECT_TIMEOUT_SECONDS=15
NEUTRINO_READ_TIMEOUT_SECONDS=120
NEUTRINO_CACHE_ENABLED=true
NEUTRINO_CACHE_TTL_SECONDS=86400

# Permite desactivar subcriterios que requieren llamadas HTTP externas.
IPREP_ALLOW_HTTP=true
DOMAINREP_ALLOW_HTTP=true
DOMAINIP_ALLOW_HTTP=true
DOMAINAGE_ALLOW_HTTP=true
CAPTCHA_ALLOW_HTTP=true

# Limites defensivos de subida para proteger memoria y base de datos.
MAX_UPLOAD_FILE_BYTES=5242880
MAX_BATCH_FILES=2000
MAX_BATCH_TOTAL_BYTES=536870912

# Arranque local de la API. La concurrencia se calcula automaticamente segun el equipo.
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=false

# Desactiva solo la desaturacion half-saturation del MCDM.
MCDM_DESATURATION_ENABLED=true
